{
  "name": "@gantry/mcp-shopify",
  "version": "0.1.0",
  "description": "Read-only Shopify Admin API MCP server for the Boondi agent.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --enable-source-maps --import tsx src/index.ts",
    "watch": "node --watch --watch-path=./src --enable-source-maps --import tsx src/index.ts",
    "debug": "node --enable-source-maps --inspect=127.0.0.1:9229 --import tsx src/index.ts",
    "debug-watch": "node --env-file=/Users/caw-d/gantry/.env --watch --watch-path=./src --enable-source-maps --inspect=127.0.0.1:9229 --import tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.0.0"
  }
}
